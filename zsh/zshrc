# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

source "$HOME/dotfiles/zsh/zinit.zsh"
source "$HOME/dotfiles/zsh/setopts.zsh"

autoload -U edit-command-line
zle -N edit-command-line
bindkey '^xe' edit-command-line
bindkey '^x^e' edit-command-line

if [[ "$TERM" == "xterm-ghostty" ]]; then
    bindkey -r "^L"
fi

fpath=($fpath $HOME/dotfiles/zsh/completion)
autoload -Uz compinit && compinit

source $HOME/dotfiles/zsh/exports.zsh
source $HOME/dotfiles/zsh/my_fzf.sh
source $HOME/dotfiles/zsh/aliases.zsh
source $HOME/dotfiles/zsh/forgit.plugin.zsh
source $HOME/dotfiles/zsh/p10k.zsh

if [[ "$(uname)" == "Darwin" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    PATH=$(brew --prefix llvm)/bin:$PATH
    if type brew &>/dev/null
    then
      FPATH="$(brew --prefix)/share/zsh/site-functions:${FPATH}"
      autoload -Uz compinit
      compinit
    fi
fi
if [[ "$TERM" == "xterm-kitty" ]]; then
    "$HOME/.config/kitty/sync-theme.sh"
    export TERM_FEATURES=P
fi

eval "$(direnv hook zsh)"

# atuin: shell history search (Ctrl-R). Must come after the fzf plugin so it
# wins the Ctrl-R binding. --disable-up-arrow keeps the default up-arrow history.
if command -v atuin &>/dev/null; then
    eval "$(atuin init zsh --disable-up-arrow)"
fi

